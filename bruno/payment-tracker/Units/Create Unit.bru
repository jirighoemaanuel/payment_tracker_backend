meta {
  name: Create Unit
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/units
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Block A - Room 4",
    "category": "1 Bedroom",
    "description": "Ground floor unit with prepaid meter",
    "rentAmount": 250000,
    "status": "available"
  }
}

vars:pre-request {
  baseUrl: http://localhost:5000/api/v1
}
